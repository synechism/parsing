{
  "name": "parsing",
  "version": "1.0.0",
  "description": "Async FastAPI service for agent workflows, backed by MinerU running in a dedicated GPU container.",
  "main": "src/mastra/index.ts",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "dev:mastra": "mastra dev",
    "build:mastra": "mastra build",
    "dev:table-agent": "tsx src/table-compare/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && npm run test:table-unit",
    "test:table-unit": "tsx scripts/test_table_compare_unit.ts",
    "test:table-e2e": "tsx scripts/test_table_compare_e2e.ts",
    "test:table-semantic-e2e": "tsx scripts/test_table_compare_semantic_e2e.ts",
    "generate:table-fixtures": "tsx scripts/generate_table_fixtures.ts",
    "create:table-examples": "tsx scripts/create_table_example_runs.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/synechism/parsing.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/synechism/parsing/issues"
  },
  "homepage": "https://github.com/synechism/parsing#readme",
  "dependencies": {
    "@mastra/core": "^1.41.0",
    "cheerio": "^1.2.0",
    "express": "^5.2.1",
    "mastra": "^1.12.2",
    "multer": "^2.1.1",
    "pdf-lib": "^1.17.1",
    "pngjs": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.2",
    "@types/pngjs": "^6.0.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
